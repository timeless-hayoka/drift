# DRIFT API Configuration
# Copy to .env and fill in your values

# LLM Provider
DRIFT_API_KEY=your_gemini_api_key_here
DRIFT_PRIMARY_MODEL=gemini-2.5-flash
DRIFT_CRITIC_MODEL=gemini-2.5-flash

# Local LLM Fallback (Ollama)
DRIFT_USE_LOCAL_FALLBACK=true
DRIFT_LOCAL_MODEL=qwen3:4b
OLLAMA_HOST=http://localhost:11434

# API Server
DRIFT_API_HOST=0.0.0.0
DRIFT_API_PORT=8080
DRIFT_API_WORKERS=1

# Security
DRIFT_AUTHORIZED_TARGETS=

# Cognitive Settings
REFLECTION_INTERVAL=10

# Vector DB
DRIFT_CHROMA_PERSIST_DIR=./chroma_db
